<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>LenDenClub Flat Interest Rolling Simulator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --ink:#0a0c0f;--paper:#f0ede8;--line:#d4cfc8;--line2:#e8e4df;
  --blue:#1a56ff;--green:#0d8a4e;--red:#c0392b;--amber:#b8860b;
  --teal:#0e7490;--purple:#5b21b6;--text:#1a1a1a;--muted:#6b6560;--dim:#a09b94;
}
body{background:var(--paper);color:var(--text);font-family:'IBM Plex Sans',sans-serif;min-height:100vh;max-width:480px;margin:0 auto;padding-bottom:80px}

/* HEADER */
.hdr{background:var(--ink);padding:20px 18px 16px;position:relative;overflow:hidden}
.h-chip{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:4px;padding:3px 8px;font-family:'IBM Plex Mono',monospace;font-size:9px;color:rgba(255,255,255,.5);letter-spacing:1px;margin-bottom:10px}
.h-title{font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:700;color:#fff;letter-spacing:-1px;line-height:1.1}
.h-title span{color:#4dffb4}
.h-row{display:flex;gap:20px;margin-top:16px}
.h-stat{flex:1}
.h-stat label{font-family:'IBM Plex Mono',monospace;font-size:8px;color:rgba(255,255,255,.4);letter-spacing:2px;text-transform:uppercase;display:block;margin-bottom:4px}
.h-stat .hv{font-family:'IBM Plex Mono',monospace;font-size:15px;font-weight:700;color:#fff}
.h-stat .hv.green{color:#4dffb4}

/* RULE CARD */
.rule-banner{background:#1a56ff;padding:12px 18px;display:flex;gap:10px;align-items:flex-start}
.rb-icon{font-size:16px;margin-top:1px;flex-shrink:0}
.rb-text{font-size:11px;color:#fff;line-height:1.6;opacity:.9}

/* NAV */
.nav{display:flex;background:#fff;border-bottom:2px solid var(--ink);position:sticky;top:0;z-index:100}
.nb{flex:1;padding:11px 2px 9px;border:none;background:none;color:var(--muted);font-size:10px;font-family:'IBM Plex Mono',monospace;cursor:pointer;font-weight:600;position:relative;}
.nb.on{color:var(--ink)}
.nb.on::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:2px;background:var(--ink)}

/* PANES */
.pane{display:none;padding:14px 16px}
.pane.on{display:block}
.sec-label{font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--dim);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.sec-label::after{content:'';flex:1;height:1px;background:var(--line)}

/* GRID STATS */
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line);border:1px solid var(--line);margin-bottom:14px}
.sbox{background:var(--paper);padding:13px}
.sbox label{font-family:'IBM Plex Mono',monospace;font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:1.5px;display:block;margin-bottom:5px}
.sbox .sv{font-family:'IBM Plex Mono',monospace;font-size:17px;font-weight:700;line-height:1}

/* TABLE */
.tbl-wrap{overflow-x:auto;overflow-y:auto;max-height:560px;border:1px solid var(--line)}
table{width:100%;border-collapse:collapse;font-size:10.5px;min-width:560px}
th{background:var(--ink);color:rgba(255,255,255,.8);padding:9px 8px;text-align:right;font-family:'IBM Plex Mono',monospace;font-size:9px}
th:first-child{text-align:left;padding-left:12px}
td{padding:8px 8px;border-bottom:1px solid var(--line2);text-align:right;font-family:'IBM Plex Mono',monospace}
td:first-child{text-align:left;padding-left:12px;font-family:'IBM Plex Sans',sans-serif;font-weight:500}

/* SETTINGS */
.sf{margin-bottom:14px}
.sf label{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:1.5px;display:flex;justify-content:space-between;margin-bottom:6px}
.finput{width:100%;padding:10px 12px;background:#fff;border:1px solid var(--line);font-size:14px;font-family:'IBM Plex Mono',monospace;outline:none}
.trow{display:flex;border:1px solid var(--line)}
.tbtn{flex:1;padding:9px 4px;border:none;border-right:1px solid var(--line);background:#fff;font-family:'IBM Plex Mono',monospace;cursor:pointer;font-weight:600}
.tbtn:last-child{border-right:none}
.tbtn.on{background:var(--ink);color:#fff}

.info-box{background:#fff;border-left:3px solid var(--blue);padding:12px 14px;margin-bottom:14px}
.info-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--line2)}
.info-row:last-child{border:none}
</style>
</head>
<body>

<div class="hdr">
  <div class="h-chip">⟳ FLAT INTEREST ROLLING SIMULATOR</div>
  <div class="h-title">LenDenClub<br><span>Exact Calculator</span></div>
  <div class="h-row">
    <div class="h-stat"><label>Annual Interest</label><div class="hv green" id="hInt">44%</div></div>
    <div class="h-stat"><label>Expected NPA</label><div class="hv" style="color:#ff6b6b" id="hNpa">4%</div></div>
  </div>
</div>

<div class="rule-banner">
  <div class="rb-icon">📐</div>
  <div class="rb-text"><strong>Flat Repayment Rules:</strong> Enter Annual Interest (p.a.) & Annual NPA. App automatically splits them monthly. Reinvestment runs strictly in ₹250 Multiples.</div>
</div>

<div class="nav">
  <button class="nb on" onclick="tab('dash',this)">OVERVIEW</button>
  <button class="nb" onclick="tab('sim',this)">SIMULATION</button>
  <button class="nb" onclick="tab('setup',this)">SETUP</button>
</div>

<div id="pane-dash" class="pane on">
  <div class="sec-label">Portfolio Snapshot (1 Year)</div>
  <div class="stat-grid">
    <div class="sbox"><label>Initial Capital</label><div class="sv" id="dInv">—</div></div>
    <div class="sbox"><label>Month 1 Payout</label><div class="sv" id="dEmi1" style="color:var(--blue)">—</div></div>
    <div class="sbox"><label>Total End Portfolio Value</label><div class="sv" id="dActive" style="color:var(--green)">—</div></div>
    <div class="sbox"><label>Net Profit Generated</label><div class="sv" id="dProfit" style="color:var(--amber)">—</div></div>
  </div>

  <div class="sec-label">Month-1 Micro Loan Breakdown</div>
  <div class="info-box">
    <div class="info-row"><div>Initial Investment</div><div id="b1">₹1,00,000</div></div>
    <div class="info-row"><div>Monthly Principal (After NPA)</div><div id="b3">₹32,000.00</div></div>
    <div class="info-row"><div>Monthly Interest (Fee Adjusted)</div><div id="b4">₹3,333.33</div></div>
    <div class="info-row" style="font-weight:700; color:var(--blue)"><div>Total Monthly Payout Entering Wallet</div><div id="b5">₹35,333.33</div></div>
  </div>
</div>

<div id="pane-sim" class="pane">
  <div class="tbl-wrap">
    <table>
      <thead>
        <tr>
          <th>Month</th>
          <th>Payout Recvd</th>
          <th>Principal Recvd</th>
          <th>Interest Recvd</th>
          <th>Reinvested (₹250x)</th>
          <th>Wallet Balance</th>
          <th>Total Value</th>
        </tr>
      </thead>
      <tbody id="simTbody"></tbody>
    </table>
  </div>
</div>

<div id="pane-setup" class="pane">
  <div class="sf">
    <label>Investment Amount (₹)</label>
    <input class="finput" type="number" id="sP" value="100000" oninput="go()"/>
  </div>
  <div class="sf">
    <label>Expected Annual Interest Rate (p.a. %)</label>
    <input class="finput" type="number" id="sI" value="44" oninput="go()"/>
  </div>
  <div class="sf">
    <label>Expected Annual NPA Rate (%)</label>
    <input class="finput" type="number" id="sN" value="4" oninput="go()"/>
  </div>
  <div class="sf">
    <label>Loan Tenure</label>
    <div class="trow">
      <button class="tbtn on" onclick="setT(3,this)">3 Months</button>
    </div>
  </div>
</div>

<script>
let tenure = 3;
const fmt = n => '₹' + Math.round(n).toLocaleString('en-IN');
const fmtDec = n => '₹' + n.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2});

function tab(id, btn) {
  document.querySelectorAll('.nb').forEach(b => b.classList.remove('on'));
  document.querySelectorAll('.pane').forEach(p => p.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('pane-' + id).classList.add('on');
}

function setT(t, btn) {
  tenure = t;
  document.querySelectorAll('.trow .tbtn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  go();
}

function go() {
  const P = +document.getElementById('sP').value || 100000;
  const annualInterestPct = +document.getElementById('sI').value || 44;
  const annualNpaPct = +document.getElementById('sN').value || 4;

  document.getElementById('hInt').textContent = annualInterestPct + '%';
  document.getElementById('hNpa').textContent = annualNpaPct + '%';

  // Core Math Logic matching LenDenClub screenshot
  // 1. Principal repayment velocity: 1/3rd per month, reduced by monthly pro-rata NPA share
  // Monthly NPA rate = Annual NPA / 12 months. Over 3 months, total NPA hit is exactly the Annual NPA % specified.
  const monthlyNpaFactor = (annualNpaPct / 100) / 12;
  const monthlyPrincipalRate = (1 / tenure) - monthlyNpaFactor;
  const monthlyPrincipal = P * monthlyPrincipalRate;

  // 2. Interest calculation: Flat interest rate derived from Annual input
  // Net Monthly Interest Rate = (Annual Interest % / 12) - Platform Fee (0.33%)
  const monthlyGrossInterestRate = (annualInterestPct / 100) / 12;
  const monthlyNetInterestRate = monthlyGrossInterestRate - 0.00333333;
  const monthlyInterest = P * monthlyNetInterestRate;
  
  const monthlyPayout = monthlyPrincipal + monthlyInterest;

  document.getElementById('b1').textContent = fmt(P);
  document.getElementById('b3').textContent = fmtDec(monthlyPrincipal);
  document.getElementById('b4').textContent = fmtDec(monthlyInterest);
  document.getElementById('b5').textContent = fmtDec(monthlyPayout);

  // 12 Months Simulation Book Execution
  let wallet = 0;
  let activeLoans = [{ initialAmt: P, remMonths: tenure }];
  const tbody = document.getElementById('simTbody');
  tbody.innerHTML = '';

  // Initial Month 0 Row
  let tr0 = document.createElement('tr');
  tr0.innerHTML = `<td>Start</td><td>—</td><td>—</td><td>—</td><td>${fmt(P)}</td><td>₹0</td><td>${fmt(P)}</td>`;
  tbody.appendChild(tr0);

  let m1Emi = 0;
  let finalPortfolio = 0;

  for (let m = 1; m <= 12; m++) {
    let recPrincipal = 0;
    let recInterest = 0;
    let nextLoans = [];

    // Process all running loan blocks rolling over
    for (let loan of activeLoans) {
      const mPrin = loan.initialAmt * monthlyPrincipalRate;
      const mInt = loan.initialAmt * monthlyNetInterestRate;

      recPrincipal += mPrin;
      recInterest += mInt;

      if (loan.remMonths > 1) {
        nextLoans.push({ initialAmt: loan.initialAmt, remMonths: loan.remMonths - 1 });
      }
    }

    let totalPayoutReceived = recPrincipal + recInterest;
    if (m === 1) m1Emi = totalPayoutReceived;

    wallet += totalPayoutReceived;

    // Rolling Reinvestment Rule strictly in multiples of ₹250 units
    let reinvestedThisMonth = Math.floor(wallet / 250) * 250;
    wallet = wallet - reinvestedThisMonth;

    if (reinvestedThisMonth > 0) {
      nextLoans.push({ initialAmt: reinvestedThisMonth, remMonths: tenure });
    }

    activeLoans = nextLoans;

    // Portfolio Valuation: Cumulative running outstanding loans + wallet cash asset
    let outstandingPrincipal = 0;
    for (let loan of activeLoans) {
      outstandingPrincipal += (loan.initialAmt * monthlyPrincipalRate) * loan.remMonths;
    }
    
    let currentTotalValue = outstandingPrincipal + wallet;
    if (m === 12) finalPortfolio = currentTotalValue;

    let tr = document.createElement('tr');
    tr.innerHTML = `
      <td>Month ${m}</td>
      <td style="color:var(--blue); font-weight:600">${fmtDec(totalPayoutReceived)}</td>
      <td>${fmtDec(recPrincipal)}</td>
      <td style="color:var(--green)">${fmtDec(recInterest)}</td>
      <td style="color:var(--purple)">${fmt(reinvestedThisMonth)}</td>
      <td>${fmtDec(wallet)}</td>
      <td style="font-weight:700; color:var(--ink)">${fmt(currentTotalValue)}</td>
    `;
    tbody.appendChild(tr);
  }

  // Dashboard Summary Updation
  document.getElementById('dInv').textContent = fmt(P);
  document.getElementById('dEmi1').textContent = fmtDec(m1Emi);
  document.getElementById('dActive').textContent = fmt(finalPortfolio);
  document.getElementById('dProfit').textContent = fmt(finalPortfolio - P);
}

go();
</script>
</body>
</html>

